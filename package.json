{
  "name": "share-album",
  "version": "0.1.0",
  "private": true,
  "description": "Shared album service with AI tagging.",
  "scripts": {
    "dev": "pnpm --parallel --filter web --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api start:dev",
    "build": "pnpm -r --if-present build",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "db:generate": "pnpm --filter api prisma:generate",
    "db:migrate": "pnpm --filter api prisma:migrate",
    "supabase:init": "pnpm exec supabase init",
    "supabase:start": "pnpm exec supabase start",
    "supabase:stop": "pnpm exec supabase stop"
  },
  "devDependencies": {
    "supabase": "latest"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  }
}
